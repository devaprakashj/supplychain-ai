# SupplyChain AI – Backend Environment Configuration
# Copy this file to backend/.env and fill in your API keys

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=SupplyChain AI
APP_ENV=development
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/supplychain

# ── CORS Origins ──────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL API KEYS
# Configure these in the Settings page of the application
# ═══════════════════════════════════════════════════════════════════════════════

# ── OpenWeatherMap (optional – Open-Meteo used as free fallback) ───────────────
# Get free key: https://openweathermap.org/api
# OPENWEATHER_API_KEY=your_key_here

# ── NewsAPI (optional – enables logistics news feed) ──────────────────────────
# Get free key: https://newsapi.org (100 requests/day free)
# NEWS_API_KEY=your_key_here

# ── OpenAI (optional – enables AI Copilot and supplier analysis) ──────────────
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here

# ── AISStream (free WebSocket AIS – enables live ship tracking) ───────────────
# Free tier: register at https://aisstream.io
# Replaces MarineTraffic (paid) – AISStream is completely free
# AISSTREAM_API_KEY=your_key_here

# ── Alpha Vantage (optional – enables commodity prices) ───────────────────────
# Get free key: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# FREE APIS (no key required – always active)
# ═══════════════════════════════════════════════════════════════════════════════
# USGS Earthquake API:   https://earthquake.usgs.gov/earthquakes/feed/v1.0
# NASA EONET:            https://eonet.gsfc.nasa.gov/api/v3
# Open-Meteo weather:    https://api.open-meteo.com/v1
# Open Exchange Rates:   https://open.er-api.com/v6/latest
# OpenStreetMap tiles:   https://tile.openstreetmap.org
# OpenSky Network:       https://opensky-network.org/api   ← NEW: free live flight tracking
